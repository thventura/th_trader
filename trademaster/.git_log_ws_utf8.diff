+// Abre uma conex├úo WebSocket e retorna quando estiver aberta
+function abrirConexao(): Promise<WebSocket | null> {
+  return new Promise((resolve) => {
+    try {
+      const ws = new WebSocket(WS_NXOS);
+      const timeout = setTimeout(() => { try { ws.close(); } catch {} resolve(null); }, 10000);
+
+      ws.onopen = () => {
+        clearTimeout(timeout);
+        resolve(ws);
+      };
+      ws.onerror = () => {
+        clearTimeout(timeout);
+        resolve(null);
+      };
+    } catch {
+      resolve(null);
+    }
+  });
+}
+
+// Envia SUBSCRIBE para um s├¡mbolo
+function enviarSubscribe(ws: WebSocket, symbol: string, interval: string) {
+  ws.send(JSON.stringify({
+    method: 'SUBSCRIBE',
+    params: { symbol, type: 'watchOHLCV', interval },
+  }));
+}
+
+// Envia GET_HISTORY e espera a resposta (uma ├║nica request-response)
+function fetchBatch(ws: WebSocket, symbol: string, to: number, count: number): Promise<Vela[]> {
+  return new Promise((resolve) => {
+    const timeout = setTimeout(() => {
+      ws.onmessage = savedHandler;
+      console.warn(`[WS] Timeout batch para ${symbol}, to=${to}`);
+      resolve([]);
+    }, 15000);
+
+    const savedHandler = ws.onmessage;
+
+    ws.onmessage = (event: MessageEvent) => {
+      try {
+        const dados = JSON.parse(event.data);
+
+        if (dados.historyOHLCV) {
+          clearTimeout(timeout);
+          ws.onmessage = savedHandler;
+
+          if (dados.historyOHLCV.s === 'ok' && dados.historyOHLCV.t?.length > 0) {
+            const velas = converterOHLCVNxos(
+              dados.historyOHLCV.t, dados.historyOHLCV.o, dados.historyOHLCV.h,
+              dados.historyOHLCV.l, dados.historyOHLCV.c, dados.historyOHLCV.v
+            );
+            resolve(velas);
+          } else {
+            resolve([]);
+          }
+          return;
+        }
+
+        // Mensagens n├úo-history (watchOHLCV etc) s├úo ignoradas durante batch
+      } catch (e) {
+        console.error('[WS] Erro processando mensagem durante batch:', e);
+      }
+    };
+
+    ws.send(JSON.stringify({
+      method: 'GET_HISTORY',
+      params: { symbol, interval: '1', to, countback: count, firstDataRequest: false },
