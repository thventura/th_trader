commit 37c4631ea9574e74bcc8101d750e1d459f227e67
Author: cleytin0101 <cleytonwalbi0101@gmail.com>
Date:   Wed Mar 18 19:13:15 2026 -0300

    fix: prevent phantom WebSocket reconnection when switching symbols
    
    When conectar() closes the old WebSocket to switch symbols, the onclose
    handler was firing tratarCloseWS() which scheduled a reconnect after 5
    seconds. This phantom reconnect replaced the new WebSocket mid-loading,
    causing carregarHistoricoLongo to lose its connection and fail silently.
    
    Fix: remove onclose/onerror/onmessage handlers from the old WebSocket
    before closing it, preventing the ghost reconnection timer.
    
    Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>

diff --git a/trademaster/src/lib/websocket-velas.ts b/trademaster/src/lib/websocket-velas.ts
index 5f16537..f949a75 100644
--- a/trademaster/src/lib/websocket-velas.ts
+++ b/trademaster/src/lib/websocket-velas.ts
@@ -119,6 +119,10 @@ class ServicoVelas {
       console.log(`[WS] Fechando conex├úo anterior para reconectar com ${wsSymbol}`);
       if (this.reconectarTimer) { clearTimeout(this.reconectarTimer); this.reconectarTimer = null; }
       const oldWs = this.ws;
+      // Remover handlers ANTES de fechar ÔÇö impede que onclose agende reconex├úo fantasma
+      oldWs.onclose = null;
+      oldWs.onerror = null;
+      oldWs.onmessage = null;
       this.ws = null;
       this.conectando = false;
       oldWs.close();
