VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_GEMINI_API_KEY=your_gemini_api_key

# Backend-only (não usar prefixo VITE_ — não devem aparecer no bundle do frontend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VAPID_EMAIL=mailto:seu@email.com
VAPID_PRIVATE_KEY=your_vapid_private_key
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# URL de produção do site (usado para restringir CORS nas APIs)
APP_URL=https://seu-site.vercel.app

# VPS do bot
VPS_API_TOKEN=your_vps_api_token
VPS_HOST=your_vps_ip
VPS_PORT=3001
